{
  "name": "datascope---saas-de-gestão-de-pesquisas",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit --skipLibCheck",
    "lint": "echo 'Linting...' && npm run type-check",
    "test": "echo 'Running tests...' && npm run type-check && npm run build",
    "deploy:staging": "npm run build && echo 'Deploy para staging...'",
    "deploy:prod": "npm run build && echo 'Deploy para produção...'",
    "cap:sync": "cap sync",
    "cap:android": "cap sync android && cd android && ./gradlew assembleDebug",
    "cap:ios": "cap sync ios",
    "git:safe-push": "npm run test && git push",
    "git:force-push": "git push --force-with-lease",
    "setup": "npm install && npm run type-check"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/cli": "^7.4.3",
    "@capacitor/core": "^7.4.3",
    "@capacitor/ios": "^7.4.3",
    "@supabase/auth-ui-react": "^0.4.7",
    "@supabase/auth-ui-shared": "^0.1.8",
    "@supabase/supabase-js": "^2.58.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.2.1"
  },
  "devDependencies": {
    "@dyad-sh/react-vite-component-tagger": "^0.8.0",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}